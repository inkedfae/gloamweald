# Cloudflare Pages Functions environment variables.
# Set these in:
# Cloudflare Dashboard -> Workers & Pages -> your Pages project -> Settings -> Variables and Secrets.

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=your_order_notification_email@example.com

# Optional:
PAYPAL_ENV=sandbox
RESEND_FROM=Gloamweald <onboarding@resend.dev>
